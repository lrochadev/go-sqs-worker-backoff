
# Required
# APP_ENV=local é o gatilho que faz os binários carregarem este .env via godotenv.
# Sem essa var, o .env é ignorado — evita que endpoint de LocalStack vaze em runs prod.

APP_ENV=local
SQS_QUEUE_URL=http://localhost:4566/000000000000/planet-queue
AWS_REGION=us-east-1

# Optional — only set for LocalStack or a custom endpoint; leave empty in prod
SQS_ENDPOINT=http://localhost:4566

# Optional tuning (defaults shown)
# WORKERS=10
# POLLERS=3
# MAX_ATTEMPTS=3
# BASE_BACKOFF=2s
# MAX_BACKOFF=60s
# VISIBILITY_TIMEOUT_SECS=30
# WAIT_TIME_SECS=20
# SHUTDOWN_TIMEOUT=30s
